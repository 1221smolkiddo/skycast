# SkyCast Environment Variables


# Required: Your OpenWeatherMap API key
# Get one free at https://openweathermap.org/api
OWM_API_KEY=your_key_here

# Optional: Anthropic API key for AI weather insights
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here
# Cache TTL in seconds (default: 600 = 10 minutes)
CACHE_TTL=600

# SQLite database path
DB_PATH=skycast.db
